# LinkedIn credentials — used only if the saved browser session has expired
LI_EMAIL=you@example.com
LI_PASSWORD=your-password

# The LinkedIn jobs search the scanner walks. Bake your keywords/filters in here;
# f_TPR=r86400 restricts to postings from the last 24 hours.
LI_JOBS_URL=https://www.linkedin.com/jobs/search-results/?keywords=data%20ai%20ml&f_TPR=r86400

# Claude API key — powers the resume-vs-job-description scorer
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Telegram notifications (silent no-op if missing)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: point at an existing logged-in Chromium profile instead of
# the default .browser_profile/ in the repo root
# BROWSER_PROFILE=D:\path\to\.browser_profile
